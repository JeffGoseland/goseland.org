---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Jeff Goseland | ML Engineer",
  description = "Principal ML Engineer with production experience at Walmart and Acorns, exploring music cognition and human-centered AI systems.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Jeff Goseland" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-2EN52KMTVT"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-2EN52KMTVT");
    </script>
  </head>
  <body>
    <header>
      <div class="container">
        <nav aria-label="Main">
          <a class="site-name" href="#intro">Jeff Goseland</a>
          <ul>
            <li><a href="#work">Work</a></li>
            <li><a href="#projects">Projects</a></li>
            <li><a href="#about">About</a></li>
            <li><a href="#contact">Contact</a></li>
          </ul>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <div class="container">&copy; {new Date().getFullYear()} Jeff Goseland</div>
    </footer>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
