---
import type { Project } from "../types";

type Props = Project;

const { title, description, bullets, extraParagraph, metrics, links } = Astro.props;
---

<article class="card">
  <h3>{title}</h3>
  <p>{description}</p>
  {
    bullets && bullets.length > 0 && (
      <ul>
        {bullets.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    )
  }
  {extraParagraph && <p set:html={extraParagraph} />}
  {
    metrics && metrics.length > 0 && (
      <div class="metrics">
        {metrics.map((metric) => (
          <span set:html={metric} />
        ))}
      </div>
    )
  }
  <div class="links">
    {
      links.map((link) => (
        <a href={link.href} target="_blank" rel="noopener noreferrer">
          {link.label}
        </a>
      ))
    }
  </div>
</article>
