---
import Layout from "../layouts/Layout.astro";
import EducationEntry from "../components/EducationEntry.astro";
import { educationRecords } from "../data/education.ts";
---

<Layout
  currentPage="education"
  title="Education | Jeff Goseland"
  description="Academic background in data science and computer information systems."
>
  <div class="page page-wide">
    <h2>Education</h2>
    {educationRecords.map((entry) => (
      <EducationEntry {...entry} />
    ))}
  </div>
</Layout>
