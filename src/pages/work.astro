---
import Layout from "../layouts/Layout.astro";
import ResumeEntry from "../components/ResumeEntry.astro";
import { workRoles } from "../data/work.ts";
---

<Layout
  currentPage="work"
  title="Work | Jeff Goseland"
  description="Professional experience in supply chain optimization, replenishment systems, and production ML."
>
  <div class="page page-wide">
    <h2>Professional Experience</h2>
    {workRoles.map((entry) => (
      <ResumeEntry {...entry} />
    ))}
  </div>
</Layout>
